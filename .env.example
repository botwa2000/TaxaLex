# TaxAlex — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Drafter, Adversary, Consolidator (required)
OPENAI_API_KEY=sk-...               # Optional fallback
GOOGLE_AI_API_KEY=...               # Reviewer — Gemini 1.5 Pro (required for pipeline)
PERPLEXITY_API_KEY=pplx-...         # Fact-checker — Sonar Pro (required for pipeline)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth (optional — enables Google sign-in button)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/taxalex

# ── Analytics (public — safe to expose, loaded after cookie consent) ──────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Payments (Phase 2) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Storage (Phase 2) ─────────────────────────────────────────────────────────
# S3_ENDPOINT=https://...
# S3_BUCKET=taxalex-uploads
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
