# TaxAlex deployment credentials
# Copy to .secrets and fill in real values — this file is committed, .secrets is not
#
# Usage: sourced automatically by scripts/deploy.sh
# Never commit .secrets to git

# ── Hetzner server ────────────────────────────────────────────────────────────
HETZNER_HOST=
HETZNER_USER=root
HETZNER_SSH_KEY=~/.ssh/id_rsa        # local key that has root access to HETZNER_HOST

# ── API keys (used to create/rotate Docker Swarm secrets on the server) ───────
ANTHROPIC_API_KEY_PROD=
ANTHROPIC_API_KEY_DEV=
OPENAI_API_KEY_PROD=
OPENAI_API_KEY_DEV=
# NEXTAUTH_SECRET is auto-generated if not set; set only to pin a specific value
NEXTAUTH_SECRET_PROD=
NEXTAUTH_SECRET_DEV=

# ── PostgreSQL — TaxaLex databases on Hetzner VPS ────────────────────────────
# Host: 172.17.0.1 is the Docker bridge gateway (reachable from all containers)
DATABASE_URL_PROD=postgresql://taxalex:PASSWORD@172.17.0.1:5432/taxalex
DATABASE_URL_DEV=postgresql://taxalex:PASSWORD@172.17.0.1:5432/taxalex_dev

# ── Cron authentication ───────────────────────────────────────────────────────
# Bearer token for /api/cron/cleanup. Generate with: openssl rand -hex 32
CRON_SECRET_PROD=
CRON_SECRET_DEV=
