{
  "mcpServers": {
    "github": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "--prefix", "/tmp/context7", "@upstash/context7-mcp@latest"]
    },
    "postgres": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"],
      "disabled": true,
      "note": "Enable when DATABASE_URL is configured"
    }
  }
}
