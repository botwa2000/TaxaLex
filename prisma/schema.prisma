generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  PRO
  ADVISOR
  LAWYER
  ADMIN
}

enum CaseStatus {
  CREATED
  UPLOADING
  ANALYZING
  QUESTIONS
  GENERATING
  DRAFT_READY
  ADVISOR_REVIEW
  APPROVED
  SUBMITTED
  AWAITING_RESPONSE
  CLOSED_SUCCESS
  CLOSED_PARTIAL
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
}

enum CreditReason {
  PURCHASE_SINGLE
  PURCHASE_PACK
  SUBSCRIPTION_GRANT
  CASE_CREATED
  REFUND
  ADMIN_GRANT
}

enum DocumentType {
  BESCHEID
  JAHRESABSCHLUSS
  BELEG
  VOLLMACHT
  EINSPRUCH_DRAFT
  EINSPRUCH_FINAL
  BEHOERDEN_ANTWORT
  ADVISOR_NOTES
  KORRESPONDENZ
}

// ── User & Auth ───────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  passwordHash   String?
  role           UserRole  @default(USER)
  locale         String    @default("de")
  outputLanguage String    @default("de")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  stripeCustomerId         String?   @unique
  creditBalance            Int       @default(0)

  accounts                 Account[]
  sessions                 Session[]
  cases                    Case[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  subscription             Subscription?
  creditLedger             CreditLedger[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Cases ─────────────────────────────────────────────────────────────────────

model Case {
  id             String     @id @default(cuid())
  userId         String
  useCase        String
  status         CaseStatus @default(CREATED)
  bescheidData   Json?
  userAnswers    Json?
  outputLanguage String     @default("de")
  uiLanguage     String     @default("de")
  deadline       DateTime?
  submittedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  outputs   CaseOutput[]

  @@index([userId])
  @@index([status])
  @@index([deadline])
}

// ── Documents ─────────────────────────────────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  caseId        String
  name          String
  type          DocumentType @default(BESCHEID)
  storagePath   String
  mimeType      String
  sizeBytes     Int
  extractedText String?      @db.Text
  createdAt     DateTime     @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

// ── Agent Outputs ─────────────────────────────────────────────────────────────

model CaseOutput {
  id         String   @id @default(cuid())
  caseId     String
  role       String
  provider   String
  model      String
  content    String   @db.Text
  version    Int      @default(1)
  isFinal    Boolean  @default(false)
  durationMs Int?
  createdAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, isFinal])
}

// ── Content — DB-backed, admin-editable ───────────────────────────────────────

model PricingPlan {
  id           String   @id @default(cuid())
  slug         String   @unique
  userGroup    String   // "individual" | "selfemployed" | "advisor" | "lawyer"
  priceOnce    Decimal? @db.Decimal(10, 2)
  priceMonthly Decimal? @db.Decimal(10, 2)
  priceAnnual  Decimal? @db.Decimal(10, 2)
  currency     String   @default("EUR")
  isPopular    Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  stripeProductId String?  // cached after first checkout; never changes for a given plan
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  translations PricingPlanTranslation[]
  features     PricingPlanFeature[]

  @@index([userGroup])
}

model PricingPlanTranslation {
  id          String      @id @default(cuid())
  planId      String
  locale      String
  name        String
  description String?     @db.Text
  cta         String?

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, locale])
  @@index([planId])
}

model PricingPlanFeature {
  id        String      @id @default(cuid())
  planId    String
  locale    String
  text      String
  included  Boolean     @default(true)
  sortOrder Int         @default(0)

  plan PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, locale])
}

model FAQ {
  id        String   @id @default(cuid())
  locale    String
  category  String   // "general" | "pricing" | "legal" | "technical" | "advisor"
  userGroup String?  // null = all groups
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, category])
  @@index([locale, userGroup])
}

model UseCase {
  id           String   @id @default(cuid())
  slug         String   // "tax" | "jobcenter" | "rente" | etc.
  locale       String
  title        String
  shortDesc    String
  description  String   @db.Text
  deadlineText String
  deadlineDays Int
  legalBasis   String
  successRate  String?
  badge        String?
  icon         String   @default("FileText")
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale])
}

// ── Payments ──────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  stripePriceId        String
  planSlug             String
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id          String       @id @default(cuid())
  userId      String
  delta       Int          // positive = added, negative = consumed
  reason      CreditReason
  referenceId String?      // stripePaymentIntentId or caseId
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Idempotency guard — prevents double-processing the same Stripe webhook event
model StripeEvent {
  id          String    @id @default(cuid())
  stripeId    String    @unique
  type        String
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([stripeId])
}

model TrustStat {
  id        String   @id @default(cuid())
  locale    String
  value     String
  label     String
  source    String
  sourceUrl String?
  verified  Boolean  @default(true)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([locale])
}
